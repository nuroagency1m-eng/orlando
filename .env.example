# ══════════════════════════════════════════════════════════════════════════════
#  CONFIGURACION DEL SERVIDOR
# ══════════════════════════════════════════════════════════════════════════════
PORT=3001
NODE_ENV=production
CORS_ORIGIN=*

# ══════════════════════════════════════════════════════════════════════════════
#  JWT (Autenticacion)
# ══════════════════════════════════════════════════════════════════════════════
JWT_SECRET=

# ══════════════════════════════════════════════════════════════════════════════
#  SUPABASE / POSTGRESQL
# ══════════════════════════════════════════════════════════════════════════════
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ══════════════════════════════════════════════════════════════════════════════
#  ADMIN POR DEFECTO
# ══════════════════════════════════════════════════════════════════════════════
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@sistema.com
